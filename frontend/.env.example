# ── Admin password ────────────────────────────────────────────────────────────
# This is the password you type when unlocking admin mode on your portfolio.
# Must start with VITE_ so Vite exposes it to the browser.
VITE_ADMIN_PASSWORD=choose_a_strong_password_here

# ── Backend admin token ───────────────────────────────────────────────────────
# Must match ADMIN_TOKEN in your backend .env exactly.
# Used when uploading your photo or CV through the admin panel.
VITE_ADMIN_TOKEN=your_backend_admin_token_here
