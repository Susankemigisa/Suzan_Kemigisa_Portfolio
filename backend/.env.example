# ── SMTP (Gmail recommended) ─────────────────────────────────────────────────
# Use a Gmail App Password — NOT your main Gmail password.
# To get one: Google Account → Security → 2FA → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kemigisa32@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Where you want to RECEIVE the contact form messages (usually same as SMTP_USER)
TO_EMAIL=kemigisa32@gmail.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your portfolio frontend URL here (comma-separated if multiple)
# Examples: http://localhost:3000,https://kemigisasuzan.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Admin uploads ─────────────────────────────────────────────────────────────
# Set a strong secret token — used to protect the photo/CV upload endpoints.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=your_strong_secret_token_here

# Where uploaded files are stored on disk (defaults to /tmp/portfolio_uploads)
# On Vercel or serverless, use persistent storage like a volume or S3 instead.
UPLOAD_DIR=/tmp/portfolio_uploads
