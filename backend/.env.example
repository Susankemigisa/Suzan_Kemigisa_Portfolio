# ── SMTP (Gmail recommended) ─────────────────────────────────────────────────
# Use a Gmail App Password — NOT your main Gmail password.
# To get one: Google Account → Security → 2FA → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kemigisa32@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Where you want to RECEIVE the contact form messages (usually same as SMTP_USER)
TO_EMAIL=kemigisa32@gmail.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your portfolio frontend URL here (comma-separated if multiple)
# Examples: http://localhost:3000,https://kemigisasuzan.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
